{
  "name": "agentic-trading-bots",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic commodity trading dashboard with news, sentiment, and PPO bot visualizations.",
  "scripts": {
    "dev": "next dev",
    "preprocess": "sh scripts/preprocess.sh all",
    "build": "npm run preprocess && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "docs:install": "python3 -m pip install -r docs/requirements.txt",
    "docs:build": "python3 -m sphinx -b html docs out/docs",
    "train:single": "sh scripts/train-single.sh",
    "train:multi": "sh scripts/train-multi.sh",
    "predict:baseline": "sh scripts/predict-baseline.sh",
    "predict:ridge": "sh scripts/predict-ridge-arx.sh",
    "predict:ridge:sentiment": "PREDICTION_CONFIG=configs/predictions/ridge_arx_sentiment.json sh scripts/predict-ridge-arx.sh",
    "predict:ridge:price-only": "PREDICTION_CONFIG=configs/predictions/ridge_arx_price_only.json sh scripts/predict-ridge-arx.sh",
    "predict:lightgbm": "sh scripts/predict-lightgbm.sh",
    "predict:lightgbm:sentiment": "PREDICTION_CONFIG=configs/predictions/lightgbm_sentiment.json sh scripts/predict-lightgbm.sh",
    "predict:lightgbm:price-only": "PREDICTION_CONFIG=configs/predictions/lightgbm_price_only.json sh scripts/predict-lightgbm.sh",
    "predict:lightgbm:direct": "sh scripts/predict-lightgbm-direct.sh",
    "predict:lightgbm:direct:sentiment": "PREDICTION_CONFIG=configs/predictions/lightgbm_direct_sentiment.json sh scripts/predict-lightgbm-direct.sh",
    "predict:lightgbm:direct:price-only": "PREDICTION_CONFIG=configs/predictions/lightgbm_direct_price_only.json sh scripts/predict-lightgbm-direct.sh",
    "predict:gp": "sh scripts/predict-gaussian-process.sh",
    "predict:gp:sentiment": "PREDICTION_CONFIG=configs/predictions/gaussian_process_sentiment.json sh scripts/predict-gaussian-process.sh",
    "predict:gp:price-only": "PREDICTION_CONFIG=configs/predictions/gaussian_process_price_only.json sh scripts/predict-gaussian-process.sh",
    "predict:lstm": "sh scripts/predict-lstm.sh",
    "predict:lstm:sentiment": "PREDICTION_CONFIG=configs/predictions/lstm_sentiment.json sh scripts/predict-lstm.sh",
    "predict:lstm:price-only": "PREDICTION_CONFIG=configs/predictions/lstm_price_only.json sh scripts/predict-lstm.sh",
    "test:py": "sh scripts/test-py.sh",
    "test": "npm run typecheck && npm run lint && npm run test:py"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.3",
    "typescript": "^5.9.3"
  }
}
