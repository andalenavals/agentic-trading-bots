{
  "name": "agentic-trading-bots",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic commodity trading dashboard with news, sentiment, and PPO bot visualizations.",
  "scripts": {
    "dev": "next dev",
    "preprocess": "python3 -m agentic_trading.preprocessing --config configs/preprocessing/default.json all",
    "build": "npm run preprocess && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "docs:install": "python3 -m pip install -r docs/requirements.txt",
    "docs:build": "python3 -m sphinx -b html docs out/docs",
    "train:single": "python3 -m agentic_trading.training.single_asset_ppo --config configs/agents/single_asset_ppo.json",
    "train:multi": "python3 -m agentic_trading.training.multiple_asset_ppo --config configs/agents/multiple_asset_ppo.json",
    "test:py": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "test": "npm run typecheck && npm run lint && npm run test:py"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.3",
    "typescript": "^5.9.3"
  }
}
